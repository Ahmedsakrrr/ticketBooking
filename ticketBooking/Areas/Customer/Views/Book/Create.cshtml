@model Book
<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">Add Book</h2>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <form method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="name" class="form-label">Customer Name</label>
                    <input class="form-control" name="CustomerName"  />
                </div>
                <select id="movieSelect" name="MovieId" class="form-control">
                    <option value="">-- Select Movie --</option>
                    @foreach (var movie in ViewBag.Movies)
                    {
                        <option value="@movie.Id"
                                data-desc="@movie.Description"
                                data-img="@movie.MinImg"
                                 >
                            @movie.Name
                        </option>
                    }
                </select>
                <div class="mt-3">
                    <img id="movieImg" style="max-width:200px; display:none;" />
                    <p id="movieDesc"></p>
                    <p id="movieDuration"></p>
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
                <a href="/Admin/Actor/Index" class="btn btn-secondary" id="cancelBtn">Cancel</a>
            </form>
        </div>
    </div>
</div>
<script>
    document.getElementById("cancelBtn").addEventListener("click", function (e) {
        e.preventDefault();

        Swal.fire({
            title: 'Are you sure?',
            text: "Any unsaved changes will be lost!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Yes, leave!',
            cancelButtonText: 'Stay'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/Customer/Home/Index";
            }
        });
    });
</script>
<script>
    document.getElementById("movieSelect").addEventListener("change", function () {

        var selected = this.options[this.selectedIndex];

        var desc = selected.getAttribute("data-desc");
        var img = selected.getAttribute("data-img");
        var duration = selected.getAttribute("data-duration");

        if (!img) return;

        document.getElementById("movieImg").src = "/Movieimage/" + img;
        document.getElementById("movieImg").style.display = "block";

        document.getElementById("movieDesc").innerText = desc;
        document.getElementById("movieDuration").innerText = "Duration: " + duration + " min";
    });
</script>