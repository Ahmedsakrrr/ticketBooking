@model IEnumerable<Cinema>



<section class="py-3 filter-bar">
    <div class="container">
        <div class="row" style="background-color: rgba(var(--bs-light-rgb), var(--bs-bg-opacity)) !important;">
            <div class="col-12">
                <form>
                    <div class="row">
                        <!-- Cinema Name -->
                        <div class="col-md-3">
                            <input type="text" class="form-control" name="Name" value="@ViewBag.SearchTerm" placeholder="Name">
                        </div>
                        <div class="row mt-3">
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-dark w-100">Filter</button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
    </section>
<div class="container">
<div class="row mb-3 align-items-center my-3">
    <div class="col-md-6">
        <h2 class="display-6">All Cinemas</h2>
    </div>
    <div class="col-md-6 text-md-end text-start mt-2 mt-md-0">
        <a class="btn btn-success" href="/Admin/Cinema/Create">Create</a>
    </div>
</div>

<div class="row">
    <div class="col-12">

        <table class="table table-hover">
            <thead>
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">Name</th>
                    <th scope="col">Description</th>
                    <th scope="col">Img</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cinema in Model)
                    {
                        <tr>
                            <th scope="row" >@cinema.Id</th>
                            <td>@cinema.Name</td>
                            <td>@cinema.Description</td>
                            <td><img src="~/CimaImage/@cinema.Img" alt="@cinema.Name" width="100"/></td>
                         
                            
                                
                            
                            <td>
                                <a type="button" class="btn btn-warning" href="/Admin/Cinema/Edit/@cinema.Id">Edit</a>
                                <a class="btn btn-danger btn-delete"
                                       data-url="/Admin/Cinema/Delete/@cinema.Id">
                                    Delete
                                </a>
                            </td>
                           
                        </tr>
                        
                    }
                    
            </tbody>
        </table>
    </div>
</div>
</div>
<!-- #Pagination -->
<nav aria-label="Page navigation example">
    <ul class="pagination ">
        <li class="page-item @(ViewBag.currentPage == 1 ? "disabled" : "")">
            <a class="page-link" href="/Admin/Cinema/Index?page=@(ViewBag.currentPage - 1)" aria-label="Previous">
                <span aria-hidden="true">&laquo;</span>
                <span class="sr-only">Previous</span>
            </a>
        </li>
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
           
            <li class="page-item active"><a class="page-link" href="/Admin/Cinema/Index?page=@i">@i</a></li>
        }
        
        
        <li class="page-item @(ViewBag.currentPage == ViewBag.TotalPages ? "disabled" : "") ">
            <a class="page-link" href="/Admin/Cinema/Index?page=@(ViewBag.currentPage + 1)" aria-label="Next">
                <span aria-hidden="true">&raquo;</span>
                <span class="sr-only">Next</span>
            </a>
        </li>
    </ul>
</nav>



<script>
    document.querySelectorAll(".btn-delete").forEach(button => {
        button.addEventListener("click", function (e) {
            e.preventDefault();

            let url = this.dataset.url;
            let row = this.closest("tr"); // علشان نحذف الصف من الجدول

            Swal.fire({
                title: 'Are you sure?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {

                    fetch(url, {
                        method: "POST"
                    })
                    .then(res => {
                        if (res.ok) {
                            // حذف الصف من الجدول بدون refresh 🔥
                            row.remove();

                            Swal.fire(
                                'Deleted!',
                                'Cinema has been deleted.',
                                'success'
                            );
                        } else {
                            Swal.fire('Error!', 'Delete failed.', 'error');
                        }
                    });

                }
            });
        });
    });
</script>