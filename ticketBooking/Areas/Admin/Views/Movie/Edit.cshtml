@model Movie
<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">Add new Movie </h2>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <form method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="name" class="form-label">Name</label>
                    <input class="form-control" value="@Model.Name" name="Name" />
                </div>
                
                <div class="mb-3">
                    <label for="description"  class="form-label">Description</label>
                    <div class="form-floating">
                        <textarea class="form-control"   name="Description" placeholder="Leave a description here" style="height: 100px">@Model.Description</textarea>
                        <label for="description">You Description Here...</label>

                    </div>
                </div>
                <div class="mb-3">
                    <label for="Price" class="form-label">Price</label>
                    <input class="form-control" value="@Model.Price" name="Price" type="number" />
                </div>
                <div class="mb-3">
                    <label for="MinImg" class="form-label">Img</label>
                    <input type="file" name="file" class="form-control" accept="image/*" onchange="previewImage(event)">
                    <span class="text-danger"></span>

                </div>

                <div class="mb-3">
                    <img id="preview"
                         src="~/Movieimage/@Model.MinImg"
                         alt="Current Image"
                         style="max-width: 200px; border:1px solid #ccc; padding:5px; border-radius:10px;" />
                </div>
                
                <div class="mb-3">
                    <label for="DateTime" class="form-label">DateTime</label>
                    <input class="form-control" value="@Model.DateTime.ToString("yyyy-MM-ddTHH:mm")" name="DateTime" type="datetime-local" />
                </div>
                
                <div class="col-md-2">
                    <select class="form-control" name="CategoryId">
                        <option>--Select Category--</option>.
                        @if (ViewBag.Categories != null)
                        {
                            @foreach (var category in ViewBag.Categories)
                            {
                                if (ViewBag.CategoryId != null && ViewBag.CategoryId == category.Id)
                                {
                                    <option value="@category.Id" selected>@category.Name</option>
                                }
                                else
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            }
                           
                                
                        }

                            
                                
                    </select>

                    <select class="form-control" name="CinemaId">
                        <option>--Select Cinema--</option>.
                        @if (ViewBag.Cinemas != null)
                        {
                            @foreach (var cinema in ViewBag.Cinemas)
                            {
                                if (ViewBag.CinemaId != null && ViewBag.CinemaId == cinema.Id)
                                {
                                    <option value="@cinema.Id" selected>@cinema.Name</option>
                                }
                                else
                                {
                                    <option value="@cinema.Id">@cinema.Name</option>
                                }
                            }
                           
                                
                        }

                            
                                
                    </select>
                    <select class="form-control" name="ActorId">
                        <option>--Select Actors--</option>.
                        @if (ViewBag.Actors != null)
                        {
                            @foreach (var actor in ViewBag.Actors)
                            {
                                if (ViewBag.ActorId != null && ViewBag.ActorId == actor.Id)
                                {
                                    <option value="@actor.Id" selected>@actor.Name</option>
                                }
                                else
                                {
                                    <option value="@actor.Id">@actor.Name</option>
                                }
                            }
                           
                                
                        }

                            
                                
                    </select>
                </div>
                <div class="col-md-2">
                </div>
                        
                <div class="mb-3">
                    <label for="Statu" class="form-label">Statu</label>
                    <select name="Statu" class="form-select">
                        <option selected value="True">Active</option>
                        <option value="False">InActive</option>
                    </select>

                </div>
                <button type="submit" class="btn btn-primary">Submit</button>
                <a href="/Admin/Movie/Index" class="btn btn-secondary" id="cancelBtn">Cancel</a>
            </form>
        </div>
    </div>
</div>


<script>
    function previewImage(event) {
        const input = event.target;
        const preview = document.getElementById("preview");

        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                preview.src = e.target.result; // الصورة الجديدة
            }
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>

<script>
    document.getElementById("cancelBtn").addEventListener("click", function (e) {
        e.preventDefault();

        Swal.fire({
            title: 'Are you sure?',
            text: "Any unsaved changes will be lost!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Yes, leave!',
            cancelButtonText: 'Stay'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/Admin/Movie/Index";
            }
        });
    });
</script>